load("@rules_cc//cc:defs.bzl", "cc_library")

exports_files(glob(["spec/*.xml"]))

# Allocator.h is normally generated by autotools (grep _ALLOCATOR from config).
# With the default (std) allocator, it's an empty file.
genrule(
    name = "gen_allocator_h",
    outs = ["src/C++/Allocator.h"],
    cmd = "echo '// default std allocator — no custom allocator configured' > $@",
)

cc_library(
    name = "quickfix",
    srcs = glob(
        ["src/C++/*.cpp"],
        exclude = [
            "src/C++/MySQL*.cpp",
            "src/C++/PostgreSQL*.cpp",
            "src/C++/Odbc*.cpp",
            "src/C++/SSL*.cpp",
            "src/C++/ThreadedSSL*.cpp",
            "src/C++/UtilitySSL.cpp",
            "src/C++/SocketMonitor_WIN32.cpp",
            "src/C++/stdafx.cpp",
        ],
    ) + [
        ":gen_allocator_h",
    ],
    hdrs = glob([
        "src/C++/*.h",
        "src/C++/*.hpp",
        "src/C++/double-conversion/*.h",
        "src/C++/fix40/*.h",
        "src/C++/fix41/*.h",
        "src/C++/fix42/*.h",
        "src/C++/fix43/*.h",
        "src/C++/fix44/*.h",
        "src/C++/fix50/*.h",
        "src/C++/fix50sp1/*.h",
        "src/C++/fix50sp2/*.h",
        "src/C++/fixt11/*.h",
    ]),
    # The double-conversion .cc files are #included from FieldConvertors.cpp,
    # not compiled as separate translation units.
    textual_hdrs = glob(["src/C++/double-conversion/*.cc"]),
    includes = ["src/C++"],
    copts = [
        "-Wno-deprecated",
        "-Wno-unused-parameter",
        "-Wno-missing-field-initializers",
        "-Wno-sign-compare",
    ],
    linkopts = ["-lpthread"],
    visibility = ["//visibility:public"],
)
